<!-- app/views/pages/timer.html.erb -->

<div id="timer-page" class="min-h-screen flex flex-col bg-stone-50">
  <!-- 画面上部 -->
  <header class="flex items-center w-full px-8 h-16 border-b-2 border-dashed border-gray-300 shrink-0">
    <% if false %>
      <!-- running時はリンクを消す想定。今は仮条件 -->
    <% else %>
      <nav id="page-links" class="flex space-x-8">
        <%= link_to "トップに戻る", root_path,
          class: "text-blue-600 underline font-medium hover:text-blue-800 text-lg" %>

        <%= link_to "カレンダーを見る", calendar_path,
          class: "text-blue-600 underline font-medium hover:text-blue-800 text-lg" %>
      </nav>
    <% end %>
  </header>

  <!-- 画面中央 -->
  <main
    id="timer-root"
    class="flex-1 flex flex-col items-center justify-center space-y-10 pb-8"
  >
    <!-- キャラクター表示 -->
    <div id="creature-icon" class="text-[120px] leading-none">
      🥚
    </div>

    <!-- タイマー表示 -->
    <div
      id="timer-count"
      class="text-8xl font-mono text-gray-800 tracking-widest"
      aria-live="polite"
    >
      25:00
    </div>

    <!-- 操作ボタン -->
    <div id="timer-actions">
      <% if false %>
        <button
          id="stop-button"
          type="button"
          class="border-4 border-gray-800 bg-gray-100 px-20 py-4 text-2xl font-bold rounded-lg hover:bg-gray-200 transition-colors"
        >
          Stop
        </button>
      <% else %>
        <button
          id="start-button"
          type="button"
          class="border-4 border-gray-800 bg-gray-100 px-20 py-4 text-2xl font-bold rounded-lg hover:bg-gray-200 transition-colors"
        >
          Start
        </button>
      <% end %>
    </div>

    <!-- 将来の状態メッセージ・進化演出の表示領域 -->
    <div id="timer-status-message" class="min-h-[2rem] text-base text-gray-600">
      <!-- 例: 集中を開始します / 5分到達 / 25分完了 -->
    </div>
  </main>
</div>